generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  passwordHash String
  role         Role      @default(PARTNER)
  isActive     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  customers    Customer[]

  @@index([email])
  @@map("users") // Explicitly map to lowercase 'users' table
}

model Customer {
  id                  Int            @id @default(autoincrement())
  name                String
  companyName         String?
  lastYearRevenue     Float?
  idCardNumberEncrypted String
  idCardHash          String         @unique
  phone               String?
  address             String?
  status              CustomerStatus @default(FOLLOWING)
  notes               String?
  registrationDate    DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  registeredBy        User           @relation(fields: [registeredByPartnerId], references: [id])
  registeredByPartnerId Int
  jobTitle            String?        // Added jobTitle field

  @@index([registeredByPartnerId])
  @@map("customers") // Explicitly map to lowercase 'customers' table
}

enum Role {
  ADMIN
  PARTNER
}

enum CustomerStatus {
  FOLLOWING
  NEGOTIATING
  PENDING
  SIGNED
  COMPLETED
  LOST
  OTHER
}
