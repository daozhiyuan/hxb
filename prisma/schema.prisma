generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id                    Int         @id @default(autoincrement())
  name                  String?
  email                 String      @unique
  passwordHash          String
  role                  Role        @default(USER)
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  accountHolder         String?     @db.VarChar(200)
  address               String?     @db.VarChar(500)
  bankAccount           String?     @db.VarChar(100)
  bankName              String?     @db.VarChar(200)
  companyName           String?     @db.VarChar(200)
  invoiceAddress        String?     @db.VarChar(500)
  invoicePhone          String?     @db.VarChar(50)
  invoiceTitle          String?     @db.VarChar(200)
  phone                 String?     @db.VarChar(50)
  taxId                 String?     @db.VarChar(100)
  idCardNumberEncrypted String?     @db.VarChar(500)
  idCardType            String?     @default("CHINA_MAINLAND")
  followUps             FollowUp[]
  submittedAppeals      Appeal[]    @relation("PartnerAppeals")
  processedAppeals      Appeal[]    @relation("OperatorAppeals")
  appealLogs            AppealLog[]
  customers             Customer[]

  @@index([email])
  @@map("users")
}

model FollowUp {
  id           Int       @id @default(autoincrement())
  content      String
  createdAt    DateTime  @default(now())
  customerId   Int
  createdById  Int
  type         String    @default("MEETING")
  attachments  Json?
  duration     Int?      @default(30)
  location     String?   @db.VarChar(200)
  nextSteps    String?
  notes        String?
  outcome      String?   @db.VarChar(100)
  participants Json?
  sentiment    String?   @db.VarChar(20)
  createdBy    User      @relation(fields: [createdById], references: [id])
  customer     Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdById])
}

model CustomerTag {
  id        Int        @id @default(autoincrement())
  name      String
  color     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  customers Customer[] @relation("CustomerToCustomerTag")

  @@map("customer_tags")
}

model Appeal {
  id               Int          @id @default(autoincrement())
  customerName     String
  idNumber         String?      @db.Text
  idNumberHash     String
  reason           String
  evidence         String?
  status           AppealStatus @default(PENDING)
  partnerId        Int
  operatorId       Int?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  previousAppealId Int?
  remarks          String?
  adminComment     String?
  idCardType       String       @default("CHINA_MAINLAND")
  previousAppeal   Appeal?      @relation("AppealToAppeal", fields: [previousAppealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nextAppeals      Appeal[]     @relation("AppealToAppeal")
  partner          User         @relation("PartnerAppeals", fields: [partnerId], references: [id])
  operator         User?        @relation("OperatorAppeals", fields: [operatorId], references: [id])
  logs             AppealLog[]

  @@unique([partnerId, idNumberHash])
  @@index([status])
  @@index([partnerId])
  @@index([operatorId])
  @@index([previousAppealId])
}

model AppealLog {
  id         Int      @id @default(autoincrement())
  appealId   Int
  action     String
  remarks    String?
  operatorId Int
  createdAt  DateTime @default(now())
  appeal     Appeal   @relation(fields: [appealId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator   User     @relation(fields: [operatorId], references: [id])

  @@index([appealId])
  @@index([operatorId])
}

model Customer {
  id                    Int              @id @default(autoincrement())
  name                  String
  companyName           String?
  phone                 String?
  email                 String?
  status                customers_status
  notes                 String?
  registrationDate      DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  jobTitle              String?
  registeredByPartnerId Int
  address               String?
  idCardHash            String?          @unique
  idCardNumberEncrypted String?          @db.Text
  lastYearRevenue       Float?
  followUpStatus        String?          @db.VarChar(50)
  industry              String?          @db.VarChar(100)
  lastContactedAt       DateTime?
  lastFollowUpAt        DateTime?
  logs                  Json?
  nextFollowUpAt        DateTime?
  position              String?          @db.VarChar(100)
  priority              String?          @db.VarChar(20)
  source                String?          @db.VarChar(50)
  idCardType            String?          @default("CHINA_MAINLAND")
  registeredBy          User             @relation(fields: [registeredByPartnerId], references: [id])
  followUps             FollowUp[]
  tags                  CustomerTag[]    @relation("CustomerToCustomerTag")

  @@index([registeredByPartnerId])
  @@map("customers")
}

model CustomerToCustomerTag {
  A Int
  B Int

  @@unique([A, B], map: "_CustomerToCustomerTag_AB_unique")
  @@index([B], map: "_CustomerToCustomerTag_B_index")
  @@map("_CustomerToCustomerTag")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PARTNER
  USER
}

enum AppealStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  APPROVED   @map("approved")
  REJECTED   @map("rejected")
}

enum customers_status {
  FOLLOWING
  NEGOTIATING
  PENDING
  SIGNED
  COMPLETED
  LOST
}
